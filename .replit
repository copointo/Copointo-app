modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["twilio:1.0.0", "revenuecat:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
TWILIO_FROM_NUMBER = "+18146664071"
PUBLIC_API_BASE_URL = "https://copointo.com"
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY = "test_ZucTfMqPwGdHfPTytVlJzPhYmnc"
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY = "appl_djdwyRyhTmKiRLtDRvzujgjwFCw"
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY = "goog_PIppuimdqlZICVDvEAklGQJijUn"
REVENUECAT_PROJECT_ID = "proj79e8df17"
REVENUECAT_TEST_STORE_APP_ID = "app54c1d3f517"
REVENUECAT_APPLE_APP_STORE_APP_ID = "app366fc0910e"
REVENUECAT_GOOGLE_PLAY_STORE_APP_ID = "appe4f1632838"
OMPAY_ENV = "production"

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
